# Development Dockerfile
FROM node:18-alpine

# Install dependencies
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Enable pnpm with specific version
RUN corepack enable && corepack prepare pnpm@10.32.1 --activate && pnpm config set store-dir /pnpm-store

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install dependencies
RUN pnpm i --frozen-lockfile

# Expose port
EXPOSE 3000

# Command to run the development server
CMD ["sh", "-c", "pnpm dev --host 0.0.0.0 --port 3000"]
