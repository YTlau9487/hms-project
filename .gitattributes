# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must use LF
*.sh text eol=lf

# Batch files must use CRLF
*.bat text eol=crlf

# Python source
*.py text eol=lf

# JavaScript/TypeScript
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# JSON
*.json text eol=lf

# YAML/YML
*.yml text eol=lf
*.yaml text eol=lf

# HTML/CSS
*.html text eol=lf
*.css text eol=lf

# Markdown
*.md text eol=lf

# Config files
*.conf text eol=lf
*.config text eol=lf
.env text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Binary files - no normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
*.sqlite binary
*.sqlite3 binary